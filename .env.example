# ─────────────────────────────────────────────────────────────────────────────
# tg-analytics server — environment variables
#
# Copy this file to .env and fill in the values.
# Never commit .env — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────
# Token from @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=

# Your personal Telegram chat ID — only this account can interact with the bot.
# Find it by messaging @userinfobot on Telegram.
ADMIN_CHAT_ID=

# ── Database ──────────────────────────────────────────────────────────────────
# Async PostgreSQL connection string (asyncpg driver).
# Change password to something secure before deploying.
DATABASE_URL=postgresql+asyncpg://tga:changeme@db/tganalytics

# ── External services ─────────────────────────────────────────────────────────
# QuickChart URL — use the bundled container when running via docker-compose.
QUICKCHART_URL=http://quickchart:3400

# ── Security ──────────────────────────────────────────────────────────────────
# Random secret used for API key signing.  Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── Bot webhook ───────────────────────────────────────────────────────────────
# Public HTTPS URL of your server.  The bot registers its webhook at:
#   <WEBHOOK_BASE_URL>/webhook/<TELEGRAM_BOT_TOKEN>
# Leave empty to use long-polling (development only).
WEBHOOK_BASE_URL=https://your-server.com

# ── Rate limiting (optional) ──────────────────────────────────────────────────
# Maximum ingestion requests per second per API key (default: 100).
# RATE_LIMIT_PER_SECOND=100

# ── PostgreSQL container (docker-compose only) ────────────────────────────────
POSTGRES_DB=tganalytics
POSTGRES_USER=tga
POSTGRES_PASSWORD=changeme
